<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup/transfer rules. The on-device forecast cache is excluded
  from both cloud backup and device-to-device transfer (it's just re-fetchable
  NWS data); settings are allowed.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="myweather.db" />
        <exclude domain="database" path="myweather.db-wal" />
        <exclude domain="database" path="myweather.db-shm" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="myweather.db" />
        <exclude domain="database" path="myweather.db-wal" />
        <exclude domain="database" path="myweather.db-shm" />
    </device-transfer>
</data-extraction-rules>
