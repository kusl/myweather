<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
      A thin Material 3 base theme. The actual colors are driven by the Compose
      MaterialTheme (with Android 12+ dynamic color) at runtime; this XML theme
      mostly sets the window background and the splash/transition appearance.
    -->
    <style name="Theme.MyWeather" parent="android:Theme.Material.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@android:color/background_light</item>
    </style>
</resources>
